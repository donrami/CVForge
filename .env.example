# Environment variables for CVForge
# Copy this file to .env and fill in the values

# Google Gemini API key (required for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# The URL where this app is hosted (used for OAuth callbacks, etc.)
# For development, use: http://localhost:3000
APP_URL=http://localhost:3000

# Database connection string (configured for Docker Compose by default)
# Change if using an external database
DATABASE_URL=postgresql://cvforge:cvforge@db:5432/cvforge

# Auth - generate a bcrypt hash of your master password:
#   node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"
AUTH_PASSWORD_HASH=your_bcrypt_hash_here

# NextAuth secret for JWT encryption (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# NextAuth URL (must match APP_URL for production)
NEXTAUTH_URL=http://localhost:3000