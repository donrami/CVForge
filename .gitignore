# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
build/
*.tsbuildinfo

# Coverage
coverage/
*.lcov

# Logs
*.log
logs/

# Environment files
.env
.env.local
.env.*.local
.env.production
.env.development
!.env.example

