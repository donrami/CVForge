context/

# IDE
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo

# CVForge specific - User data (NEVER commit personal information)
# Keep the directory but ignore user-modified content
/context/*
!/context/master-cv.tex
!/context/certificates.md
!/context/instructions.md

# Generated files (runtime output)
/generated/*
!/generated/.gitkeep

# Prisma
prisma/migrations/*/migration_lock.toml

# Docker
.dockerignore
